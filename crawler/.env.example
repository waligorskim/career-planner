# Required: Anthropic API key for job scoring
ANTHROPIC_API_KEY=sk-ant-...

# Required: Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Required: Telegram chat ID (get from @userinfobot or @getidsbot)
TELEGRAM_CHAT_ID=-100...

# Optional: Override scoring model (default: claude-haiku-4-5-20251001)
SCORING_MODEL=claude-haiku-4-5-20251001

# Optional: Minimum score to trigger instant Telegram alert (default: 75)
ALERT_THRESHOLD=75

# Optional: Minimum score to include in daily digest (default: 50)
DIGEST_THRESHOLD=50
